{
  "cleanUrls": true,
  "framework": "vite",
  "rewrites": [
    { "source": "/(Ejemplos|models|static)/(.+)", "destination": "/$1/$2" }
  ],
  "headers": [
    {
      "source": "/(.*).wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
